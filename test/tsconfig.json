{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": ["node", "@cucumber/cucumber", "@playwright/test"]
  },
  "include": ["step-definitions/**/*.ts", "support/**/*.ts"],
  "exclude": ["node_modules", "dist", "report.html"]
}
